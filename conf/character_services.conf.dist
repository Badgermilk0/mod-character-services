[worldserver]

########################################
# Character Services Mod Configuration
########################################
#
#    CharacterServices.Enable
#        Description: Enable the character services module
#        Default:     1 - Enabled
#                     0 - Disabled
#
#    CharacterServices.NameChange.Enable
#        Description: Enable the name change service
#        Default:     1 - Enabled
#                     0 - Disabled
#
#    CharacterServices.AppearanceChange.Enable
#        Description: Enable the appearance change service
#        Default:     1 - Enabled
#                     0 - Disabled
#
#    CharacterServices.RaceChange.Enable
#        Description: Enable the race change service
#        Default:     1 - Enabled
#                     0 - Disabled
#
#    CharacterServices.FactionChange.Enable
#        Description: Enable the faction change service
#        Default:     1 - Enabled
#                     0 - Disabled
#
#    CharacterServices.ProgressionTier.Enable
#        Description: Enable the progression tier purchase service
#                    (Allows characters to purchase progression tiers up to the account's maximum achieved tier)
#        Default:     1 - Enabled
#                     0 - Disabled
#
#    CharacterServices.ProgressionTier.MaxApplicableTier
#        Description: Set the maximum tier level that can be purchased via the service
#                    (Set to 0 to allow all tiers to be purchased up to the account's max)
#                    NOTE: do NOT set this to 11 - that tier (TBC Tier 3 / Zul'Aman)
#                    is disabled in mod-individual-progression. Use 12 to cap at TBC Tier 4.
#        Default:     0 - No limit (use account's maximum tier)
#                     1-18 - Specific maximum tier limit (excluding 11)
#
#    CharacterServices.ProgressionTier.RequireAccountUnlock
#        Description: Require the tier to already be unlocked on the account (by some
#                    character completing it normally) before it can be purchased here.
#                    Set to 0 to let any character buy progression up to MaxApplicableTier
#                    (or the top tier if MaxApplicableTier is 0) without prior unlock.
#                    Tiers must still be purchased one at a time, in order.
#        Default:     1 - Enabled (require account to have unlocked the tier)
#                     0 - Disabled (no account-unlock requirement)
#

CharacterServices.Enable = 1

CharacterServices.NameChange.Enable = 0
CharacterServices.AppearanceChange.Enable = 0
CharacterServices.RaceChange.Enable = 0
CharacterServices.FactionChange.Enable = 0
CharacterServices.ProgressionTier.Enable = 1
CharacterServices.ProgressionTier.MaxApplicableTier = 0
CharacterServices.ProgressionTier.RequireAccountUnlock = 1

#
#    CharacterServices.DynamicCost.Enable
#        Description: Enables scaling cost based on the player's level: (player level / 80) * cost
#                    NOTE: this applies ONLY to the name/appearance/race/faction services
#                    below. Progression tier costs are always the flat per-tier value
#                    configured in CharacterServices.Cost.ProgressionTier.X .
#        Default:     1 - Enabled
#                     0 - Disabled
#
#    CharacterServices.Cost.NameChange
#        Description: The cost to purchase a name change in gold
#        Default:     25
#
#    CharacterServices.Cost.AppearanceChange
#        Description: The cost to purchase an appearance change in gold
#        Default:     50
#
#    CharacterServices.Cost.RaceChange
#        Description: The cost to purchase a race change in gold
#        Default:     100
#
#    CharacterServices.Cost.FactionChange
#        Description: The cost to purchase a faction change in gold
#        Default:     250
#

CharacterServices.DynamicCost.Enable = 0

CharacterServices.Cost.NameChange = 25
CharacterServices.Cost.AppearanceChange = 50
CharacterServices.Cost.RaceChange = 100
CharacterServices.Cost.FactionChange = 250

#
#    CharacterServices.Cost.ProgressionTier.X
#        Description: The cost to purchase specific progression tier X in gold
#                    Note: These costs are per tier, not cumulative
#
#    Progression Tier Reference (value + name exactly as defined by
#    mod-individual-progression). Buying a tier marks that tier's content
#    COMPLETE on the character, which unlocks the following bracket:
#        0  PROGRESSION_START          (Starting state - nothing to purchase)
#        1  PROGRESSION_MOLTEN_CORE    (Molten Core)
#        2  PROGRESSION_ONYXIA         (Onyxia's Lair)
#        3  PROGRESSION_BLACKWING_LAIR (Blackwing Lair)
#        4  PROGRESSION_PRE_AQ         (Pre-Ahn'Qiraj / AQ gates quest line)
#        5  PROGRESSION_AQ_WAR         (AQ War Effort)
#        6  PROGRESSION_AQ             (Ahn'Qiraj)
#        7  PROGRESSION_NAXX40         (Naxxramas - Vanilla)
#        8  PROGRESSION_PRE_TBC        (Pre-TBC / Dark Portal - unlocks Karazhan, Gruul, Magtheridon)
#        9  PROGRESSION_TBC_TIER_1     (Karazhan, Gruul's Lair, Magtheridon's Lair)
#        10 PROGRESSION_TBC_TIER_2     (Serpentshrine Cavern, Tempest Keep)
#        11 PROGRESSION_TBC_TIER_3     (Zul'Aman) - DISABLED in IP: no cost entry, cannot be purchased
#        12 PROGRESSION_TBC_TIER_4     (Hyjal Summit, Black Temple)
#        13 PROGRESSION_TBC_TIER_5     (Sunwell Plateau - unlocks Northrend / WotLK leveling)
#        14 PROGRESSION_WOTLK_TIER_1   (Naxxramas, Eye of Eternity, Obsidian Sanctum)
#        15 PROGRESSION_WOTLK_TIER_2   (Ulduar)
#        16 PROGRESSION_WOTLK_TIER_3   (Trial of the Crusader)
#        17 PROGRESSION_WOTLK_TIER_4   (Icecrown Citadel)
#        18 PROGRESSION_WOTLK_TIER_5   (Ruby Sanctum)
#

# Vanilla progression costs

# Buying a progression tier, completes that progression tier. 
# Example: buying TBC Tier 5 lets you go to Northrend and level to 80.

# Molten Core
CharacterServices.Cost.ProgressionTier.1 = 150
# Onyxia
CharacterServices.Cost.ProgressionTier.2 = 200
# Blackwing Lair
CharacterServices.Cost.ProgressionTier.3 = 250
# Pre-AQ
CharacterServices.Cost.ProgressionTier.4 = 300
# AQ War Effort
CharacterServices.Cost.ProgressionTier.5 = 325
# AQ
CharacterServices.Cost.ProgressionTier.6 = 350
# Naxx40
CharacterServices.Cost.ProgressionTier.7 = 400
# Pre-TBC
CharacterServices.Cost.ProgressionTier.8 = 600

# TBC progression costs
# TBC Tier 1 (Karazhan, Gruul, Magtheridon)
CharacterServices.Cost.ProgressionTier.9 = 1000
# TBC Tier 2 (SSC, TK)
CharacterServices.Cost.ProgressionTier.10 = 1250
# (Tier 11 / TBC Tier 3 / Zul'Aman is disabled in IP - intentionally no entry)
# TBC Tier 4 (Hyjal, BT)
CharacterServices.Cost.ProgressionTier.12 = 1500
# TBC Tier 5 (Sunwell)
CharacterServices.Cost.ProgressionTier.13 = 1700

# WotLK progression costs
# WotLK Tier 1 (Naxx, EoE, OS)
CharacterServices.Cost.ProgressionTier.14 = 2000
# WotLK Tier 2 (Ulduar)
CharacterServices.Cost.ProgressionTier.15 = 2500
# WotLK Tier 3 (TotC)
CharacterServices.Cost.ProgressionTier.16 = 3000
# WotLK Tier 4 (ICC)
CharacterServices.Cost.ProgressionTier.17 = 3500
# WotLK Tier 5 (Ruby Sanctum)
CharacterServices.Cost.ProgressionTier.18 = 4000
